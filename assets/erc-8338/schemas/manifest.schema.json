{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/skill-token/manifest.schema.json",
  "title": "Skill Manifest (KERNEL v4.3, normative minimal schema)",
  "type": "object",
  "required": ["schemaVersion", "name", "skillVersion", "summary", "entrypoint"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "name":          { "type": "string", "minLength": 1 },
    "skillVersion":  { "type": "string", "minLength": 1 },
    "summary":       { "type": "string", "minLength": 1 },
    "entrypoint":    { "type": "string", "minLength": 1,
                       "description": "MUST equal SkillRoot.entry.path" },
    "skillType":     { "type": "string" },
    "scopes":        { "type": "array", "items": { "type": "string" },
                       "description": "discovery/display only; on-chain semantics belong to companion standards" },
    "standard":      { "type": "string" }
  },
  "additionalProperties": true,
  "$comment": "Consumers MUST ignore unknown fields; extension fields SHOULD use namespaced keys (x-vendor/*)."
}
