{
  "$schema": "https://finchip.ai/schemas/skill/1.0.json",
  "name": "daily-finance-brief",
  "version": "0.3.1",
  "repository": "https://github.com/Sleipnirs/finchip-daily-finance-brief",
  "title": "Daily Global Finance Brief",
  "description": "Generates an English daily briefing: one-page global asset dashboard (60 instruments: 10 each across indices, blue chips, FX, commodities, rates & vol, crypto), top-10 political/economic headlines, and an analysis section (<= 500 words). Output as report.md and/or report.pdf.",
  "category": "Finance",
  "runtime": {
    "language": "python",
    "min_version": "3.10",
    "entrypoint": "daily_finance_brief.py",
    "dependencies": [
      "requests",
      "feedparser",
      "reportlab",
      "yfinance (optional, recommended)"
    ]
  },
  "invocation": {
    "modes": {
      "cli": "python daily_finance_brief.py <input.json | inline-JSON | - (stdin) | omitted for defaults>",
      "examples": [
        "python daily_finance_brief.py examples/input_empty.json",
        "python daily_finance_brief.py '{\"format\":\"md\",\"demo\":true}'"
      ],
      "http": {
        "start": "python daily_finance_brief.py --serve --port 8787",
        "call": "GET /run?format=both",
        "artifacts": [
          "GET /report.md",
          "GET /report.pdf"
        ],
        "health": "GET /health"
      }
    },
    "input_schema": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "md",
            "pdf",
            "both"
          ],
          "default": "both"
        },
        "out": {
          "type": "string",
          "default": "./out",
          "description": "output directory"
        },
        "demo": {
          "type": "boolean",
          "default": false,
          "description": "offline fixture mode for testing"
        },
        "news_count": {
          "type": "integer",
          "default": 10,
          "minimum": 1,
          "maximum": 25
        }
      }
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "generated_at": {
          "type": "string"
        },
        "md_path": {
          "type": "string",
          "description": "path to reportYYMMDD.md (UTC date stamp)"
        },
        "pdf_path": {
          "type": "string",
          "description": "path to reportYYMMDD.pdf (UTC date stamp)"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "data_sources": [
    {
      "name": "Yahoo Finance (via yfinance)",
      "role": "primary market quotes",
      "auth": "none"
    },
    {
      "name": "Stooq CSV",
      "role": "fallback market quotes",
      "auth": "none"
    },
    {
      "name": "FRED (St. Louis Fed)",
      "role": "official fallback for US Treasury yields",
      "auth": "none"
    },
    {
      "name": "CoinGecko public API",
      "role": "crypto quotes (24h)",
      "auth": "none"
    },
    {
      "name": "MarketWatch / CNBC / BBC Business / Guardian Economics / Google News RSS",
      "role": "headlines",
      "auth": "none"
    }
  ],
  "env": {
    "ANTHROPIC_API_KEY": "optional — enables Claude-generated analysis section; rule-based fallback otherwise",
    "DFB_ANTHROPIC_MODEL": "optional — override analysis model (default claude-sonnet-4-6)"
  },
  "sla": {
    "typical_runtime_seconds": "20-60 (live mode)",
    "degradation": "per-instrument fallback; report always produced, gaps marked with warnings",
    "freshness": "quotes = latest daily close / 24h crypto; news window = last 36 hours"
  },
  "disclaimer": "Informational only. Not investment advice."
}